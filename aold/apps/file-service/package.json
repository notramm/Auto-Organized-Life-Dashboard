{
  "name": "@aold/file-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r dotenv/config src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node -r dotenv/config dist/index.js",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fastify": "^5.8.5",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@aws-sdk/client-s3": "^3.1034.0",
    "@aws-sdk/s3-request-presigner": "^3.1034.0",
    "ioredis": "^5.10.1",
    "kafkajs": "^2.2.4",
    "zod": "^3.25.64",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.1",
    "@aold/shared-types": "*",
    "@aold/shared-utils": "*",
    "@aold/shared-config": "*",
    "@aold/database": "*"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.15.21",
    "ts-node-dev": "^2.0.0"
