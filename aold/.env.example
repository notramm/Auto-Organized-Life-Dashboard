# ═══════════════════════════════════════════════════════════════
# AOLD — Environment Variables Reference
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ── API Gateway ──────────────────────────────────────────────────
API_GATEWAY_PORT=3000
API_GATEWAY_HOST=0.0.0.0

# ── Auth Service ─────────────────────────────────────────────────
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_URL=http://auth-service:3001

# JWT — generate with: openssl genrsa -out private.pem 2048
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=30d

# OAuth — Google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/oauth/google/callback

# ── File Service ─────────────────────────────────────────────────
FILE_SERVICE_PORT=3002
FILE_SERVICE_URL=http://file-service:3002

# ── Search Service ───────────────────────────────────────────────
SEARCH_SERVICE_PORT=3003
SEARCH_SERVICE_URL=http://search-service:3003

# ── Insights Service ─────────────────────────────────────────────
INSIGHTS_SERVICE_PORT=3004
INSIGHTS_SERVICE_URL=http://insights-service:3004

# ── AI Processing Service (Python) ───────────────────────────────
AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://ai-processing:8000

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=aold_user
POSTGRES_PASSWORD=aold_dev_password_change_in_production
POSTGRES_DB=aold_db
DATABASE_URL=postgresql://aold_user:aold_dev_password_change_in_production@localhost:5432/aold_db

# ── Redis ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ── Apache Kafka ─────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=aold-platform
KAFKA_GROUP_ID_PREFIX=aold

# ── AWS S3 ───────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=aold-files-dev
S3_PRESIGN_EXPIRY_SECONDS=3600
CLOUDFRONT_DOMAIN=your-distribution.cloudfront.net

# ── Pinecone ─────────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=aold-embeddings

# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── Email (AWS SES) ──────────────────────────────────────────────
SES_FROM_EMAIL=noreply@yourdomain.com
SES_FROM_NAME=AOLD

# ── Frontend ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_MAX_FILE_SIZE_MB=500
