{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,
    "composite": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "exactOptionalPropertyTypes": true,
    "paths": {
      "@aold/shared-types": ["./packages/shared-types/src/index.ts"],
      "@aold/shared-utils": ["./packages/shared-utils/src/index.ts"],
      "@aold/shared-config": ["./packages/shared-config/src/index.ts"],
      "@aold/database": ["./packages/database/src/index.ts"]
    }
  },
  "exclude": ["node_modules"]
}